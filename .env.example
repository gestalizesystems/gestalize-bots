# Chave da API do Google Gemini (GRATUITA): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a usar (padrão: gemini-2.5-flash — gratuito e funcionando bem).
# Obs.: o gemini-2.0-flash teve a cota gratuita zerada; prefira o 2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Porta do painel de administração (acesse em http://localhost:4500).
ADMIN_PORT=4500

# Acesso ao painel (semente inicial da conta — usado só na 1ª vez para criar data/conta.json).
ADMIN_EMAIL=seu-email@exemplo.com
ADMIN_SENHA=troque-esta-senha

# Chave GRATUITA do OpenRouteService para calcular distância pelo endereço do cliente.
# Crie em: https://openrouteservice.org/dev/#/signup (sem cartão de crédito).
# Se ficar vazio, o bot ainda calcula por km informado, mas não geolocaliza endereço.
ORS_API_KEY=

# ===== WhatsApp Cloud API (oficial da Meta) — para produção =====
# Passo a passo em MIGRACAO.md. Sem isso, o bot sobe mas não envia/recebe.
# Fonte 1 (fallback): token + phone id direto no .env.
WHATSAPP_TOKEN=          # Token de acesso (System User permanente) do app na Meta
WHATSAPP_PHONE_ID=       # Phone Number ID do número (no WhatsApp Manager)
WHATSAPP_VERIFY_TOKEN=   # Uma senha que VOCÊ inventa; usada na verificação do webhook
# WHATSAPP_API_VERSION=v21.0   # opcional (padrão: v21.0)

# ===== Coexistência (Embedded Signup) — conectar o número da loja pelo painel =====
# Com isso, dá pra conectar em /conectar-whatsapp mantendo o app do celular funcionando.
# Crie a config de Embedded Signup no App Meta (Facebook Login for Business) → gera o CONFIG_ID.
META_APP_ID=             # App ID do seu app na Meta
META_APP_SECRET=         # App Secret (fica SÓ no backend; nunca exponha no front)
META_ES_CONFIG_ID=       # ID da configuração de Embedded Signup (com coexistência habilitada)
